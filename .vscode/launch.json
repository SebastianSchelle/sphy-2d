{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Client",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/deploy/game-client",
            "args": [
                "-w",
                "${workspaceFolder}/deploy",
            ],
            "cwd": "${workspaceFolder}/deploy",
            "stopOnEntry": false
        },
        {
            "name": "Debug Server",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/deploy/game-server",
            "args": [
                "-w",
                "${workspaceFolder}/deploy",
                "-s",
                "${env:HOME}/Documents/galaxies/test-game-2"
            ],
            "cwd": "${workspaceFolder}/deploy",
            "stopOnEntry": false
        },
        {
            "name": "Debug Storage Allocator",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/sphy-2d/build/test-shelf-allocator",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false
        }
    ]
}